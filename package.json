  "private": true,
  "scripts": {
    "predev": "node -e \"const fs=require('fs');fs.mkdirSync('public/workers',{recursive:true});fs.copyFileSync('node_modules/pdfjs-dist/build/pdf.worker.min.mjs','public/workers/pdf.worker.min.mjs')\"",
    "prebuild": "node -e \"const fs=require('fs');fs.mkdirSync('public/workers',{recursive:true});fs.copyFileSync('node_modules/pdfjs-dist/build/pdf.worker.min.mjs','public/workers/pdf.worker.min.mjs')\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
